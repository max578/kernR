Package: kernR
Title: Kernel-Based Causal Distributional Testing
Version: 0.0.0.9000
Authors@R: c(
    person("Max", "Moldovan", , "maksim.pashkevich@adelaide.edu.au",
           role = c("aut", "cre"),
           comment = c(ORCID = "0000-0001-9680-8474")),
